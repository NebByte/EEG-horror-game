# Copy to .env and adjust. All values have sensible defaults for local dev.

# --- API ---
ENVIRONMENT=development
API_PREFIX=/v1

# --- Generative asset provider ---
# "mock"  -> fully offline, no cloud creds (default)
# "vertex" -> Google Cloud Vertex AI (Gemini + Imagen)
ASSET_PROVIDER=mock

# --- Google Cloud (only used when ASSET_PROVIDER=vertex) ---
GCP_PROJECT=
GCP_LOCATION=us-central1
VERTEX_TEXT_MODEL=gemini-2.5-flash
# Gemini image model (…-image) uses generate_content; an imagen-* name uses
# the Imagen generate_images path — the provider picks the call from the name.
VERTEX_IMAGE_MODEL=gemini-2.5-flash-image
VERTEX_MUSIC_MODEL=lyria-002
# Audio backend: "none" (Gemini sound specs only) or "lyria" (real WAV audio).
AUDIO_PROVIDER=none
# Path to a service-account key JSON. Leave empty to use Application Default
# Credentials (gcloud auth application-default login, or a GCP runtime).
GOOGLE_APPLICATION_CREDENTIALS=
# GCS bucket for generated media (images/audio). Leave empty to return
# specs only (no media upload).
GCS_BUCKET=

# --- EEG signal processing ---
EEG_SAMPLE_RATE_HZ=256
EEG_WINDOW_SECONDS=2

# --- Safety ---
# Sustained stress above this ceiling triggers the experience back-off.
STRESS_SAFETY_CEILING=0.9
